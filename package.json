{
  "name": "elemental-machines-kiosk",
  "version": "0.1.4",
  "description": "Cross-platform Electron kiosk app for the Elemental Machines dashboard",
  "author": "Elemental Machines",
  "main": "main.js",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development WINDOWED=true electron .",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "build": {
    "appId": "io.elementalmachines.kiosk",
    "productName": "Elemental Machines Kiosk",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
